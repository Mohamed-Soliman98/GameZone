<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Game Zone | @ViewData["Title"]</title>

    <link rel="icon" type="image/png" href="~/images/playing-videogame.png" />
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/lib/select2/css/select2.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/sweetalert2/sweetalert2.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GameZone.styles.css" asp-append-version="true" />
    <style>
        body {
            background: radial-gradient(circle at top, #0a0a1a, #050510);
            color: #e5e7eb;
            font-family: 'Chakra Petch', sans-serif;
        }

        .navbar {
            background: linear-gradient(90deg, #0f0c29, #302b63, #24243e) !important;
            border-bottom: 2px solid #7c3aed;
            box-shadow: 0 0 15px rgba(124, 58, 237, 0.4);
        }

        .navbar-brand {
            color: #a855f7 !important;
            font-weight: 700;
            font-size: 1.6rem;
            text-shadow: 0 0 10px #a855f7;
        }

        .nav-link {
            color: #c4b5fd !important;
            transition: 0.3s;
        }

            .nav-link:hover {
                color: #ffffff !important;
                text-shadow: 0 0 8px #a855f7;
            }

        /* .container {
            background: rgba(15, 15, 35, 0.6);
            border: 1px solid rgba(124, 58, 237, 0.2);
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 0 20px rgba(0,0,0,0.4);
        } */

        /* footer {
            background: #0a0a1a;
            border-top: 1px solid #7c3aed !important;
            color: #a855f7 !important;
            text-align: center;
            padding: 15px 0;
        } */

            footer a {
                color: #c4b5fd !important;
                transition: 0.3s;
            }

                footer a:hover {
                    color: #ffffff !important;
                    text-shadow: 0 0 8px #a855f7;
                }

       
        .btn-primary {
            background: linear-gradient(45deg, #7c3aed, #a855f7);
            border: none;
            box-shadow: 0 0 10px rgba(168, 85, 247, 0.4);
        }

            .btn-primary:hover {
                transform: scale(1.05);
                box-shadow: 0 0 20px rgba(168, 85, 247, 0.6);
            }

    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg mb-3" data-bs-theme="dark">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">🎮 GameZone</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Games" asp-action="Index">🕹️ Games</a>
                        </li>
                       
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
          
            @RenderBody()
        </main>
    </div>

    @* <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - GameZone - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer> *@
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/select2/js/select2.min.js"></script>
    <script src="~/lib/sweetalert2/sweetalert2.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>