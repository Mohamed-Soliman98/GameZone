@model Game

@{
    ViewData["Title"] = Model.Name;
}
<div class="card game-card rounded-4 mt-5 overflow-hidden" style="min-height: 600px;">
    <div class="card-body p-0 h-100">
        <div class="row g-0" style="min-height: 600px;">
            <div class="col-md-8 px-5 py-4 d-flex flex-column justify-content-between">
                <div>
                    <h1 class="text-success fw-bolder">@Model.Name</h1>
                    <span class="badge bg-info fs-5 mb-4">@Model.Categorie?.Name</span>
                    <p class="fs-5">@Model.Description</p>
                </div>
                <div>
                    @foreach (var gameDevice in Model.Devices)
                    {
                        <i class="@gameDevice.Device.Icon me-2 fs-1 text-secondary"></i>
                    }
                </div>
            </div>
            <div class="col-md-4 p-0">
                <img src="@($"{Filesettings.ImagesPath}/{Model.Cover}")"
                     alt="@Model.Name"
                     style="width:100%; height:100%; object-fit:cover;" />
            </div>
        </div>
    </div>
</div>